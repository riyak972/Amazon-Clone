# Server
NODE_ENV=production
PORT=5000

# Database (Railway injects this automatically as DATABASE_URL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis (Railway injects this automatically as REDIS_URL)
REDIS_URL=redis://default:pass@host:6379

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_64_char_hex_secret
JWT_REFRESH_SECRET=your_other_64_char_hex_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (SendGrid)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com

# Frontend URL (set to your actual Vercel deployment URL after deploy)
FRONTEND_URL=https://your-app.vercel.app
